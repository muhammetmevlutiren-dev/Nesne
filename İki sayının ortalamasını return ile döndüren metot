using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace ConsoleApp20
{
    internal class Program
    {
        static void Main(string[] args)
        {
            double birinciSayi = 15.5;
            double ikinciSayi = 24.0;
            double sonuc = OrtalamaBul(birinciSayi, ikinciSayi);

            Console.WriteLine($"{birinciSayi} ve {ikinciSayi} sayılarının ortalaması: {sonuc}");
            Console.WriteLine($"10 ve 20'nin ortalaması: {OrtalamaBul(10, 20)}");
            Console.ReadKey();
        }

        static double OrtalamaBul(double sayi1, double sayi2)
        {
            double ortalama = (sayi1 + sayi2) / 2;
            return ortalama;
        }
    }

}

